class Solution {
    public int longestKSubstr(String s, int k) {
        // code here
               int n = s.length();
        if (k == 0) return 0;
        
        // Sliding window: left, right pointers
        int left = 0;
        int maxLen = -1;
        
        // Count frequency of characters in current window
        Map<Character, Integer> freq = new HashMap<>();
        // Count distinct characters in current window
        int distinct = 0;
        
        for (int right = 0; right < n; right++) {
            char c = s.charAt(right);
            
            // Add character to window
            freq.put(c, freq.getOrDefault(c, 0) + 1);
            if (freq.get(c) == 1) {
                distinct++;
            }
            
            // Shrink window while distinct > k
            while (distinct > k && left <= right) {
                char leftChar = s.charAt(left);
                freq.put(leftChar, freq.get(leftChar) - 1);
                if (freq.get(leftChar) == 0) {
                    distinct--;
                }
                left++;
            }
            
            // If we have exactly k distinct characters, update max length
            if (distinct == k) {
                maxLen = Math.max(maxLen, right - left + 1);
            }
        }
        
        return maxLen;
    }
}

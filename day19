class Solution {
    public int kBitFlips(int[] arr, int k) {
        // code here
         int n = arr.length;
        int[] diff = new int[n + 1];  // Difference array for flip starts/ends
        int flips = 0;
        int flipCnt = 0;
        
        for (int i = 0; i < n; i++) {
            // Update flip count from previous flips
            flipCnt += diff[i];
            
            // Current effective value
            int curr = arr[i] ^ (flipCnt % 2);
            
            if (curr == 0) {
                if (i + k > n) return -1;
                
                // Record flip start and end
                diff[i]++;
                diff[i + k]--;
                flipCnt++;
                flips++;
            }
        }
        
        return flips;
    }
}

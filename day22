import java.util.*;

class Solution {
    // Custom Pair class for queue
    static class Pair {
        Node node;
        int hd;

        Pair(Node node, int hd) {
            this.node = node;
            this.hd = hd;
        }
    }

    public ArrayList<ArrayList<Integer>> verticalOrder(Node root) {
        ArrayList<ArrayList<Integer>> result = new ArrayList<>();
        if (root == null) return result;

        // HashMap to store horizontal distance -> list of nodes
        HashMap<Integer, ArrayList<Integer>> map = new HashMap<>();
        // Queue for BFS: pair of node and its horizontal distance
        Queue<Pair> queue = new LinkedList<>();
        queue.add(new Pair(root, 0));

        int minHd = 0, maxHd = 0;

        // BFS traversal
        while (!queue.isEmpty()) {
            Pair current = queue.poll();
            Node node = current.node;
            int hd = current.hd;

            // Add node data to the map for this hd
            map.computeIfAbsent(hd, k -> new ArrayList<>()).add(node.data);

            // Enqueue left child with hd - 1
            if (node.left != null) {
                queue.add(new Pair(node.left, hd - 1));
            }
            // Enqueue right child with hd + 1
            if (node.right != null) {
                queue.add(new Pair(node.right, hd + 1));
            }

            // Update min and max hd
            minHd = Math.min(minHd, hd);
            maxHd = Math.max(maxHd, hd);
        }

        // Collect results from leftmost to rightmost vertical line
        for (int i = minHd; i <= maxHd; i++) {
            result.add(map.get(i));
        }

        return result;
    }
}

class Solution {
    Node pred = null, succ = null;
    
    public ArrayList<Node> findPreSuc(Node root, int key) {
        pred = null;
        succ = null;
        
        traverse(root, key);
        
        ArrayList<Node> result = new ArrayList<>();
        result.add(pred);
        result.add(succ);
        return result;
    }
    
    private void traverse(Node node, int key) {
        if (node == null) return;
        
        // Left subtree
        traverse(node.left, key);
        
        // Update predecessor and successor
        if (node.data < key) {
            // Closest node smaller than key
            if (pred == null || node.data > pred.data) {
                pred = node;
            }
        } else if (node.data > key) {
            // Closest node larger than key
            if (succ == null || node.data < succ.data) {
                succ = node;
            }
        }
        
        // Right subtree
        traverse(node.right, key);
    }
}

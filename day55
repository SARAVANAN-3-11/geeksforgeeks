class Solution {
    boolean canFormPalindrome(String s) {
        int[] count = new int[26];
        for (char c : s.toCharArray()) {
            count[c - 'a']++;
        }
        int oddCount = 0;
        for (int freq : count) {
            if (freq % 2 == 1) {
                oddCount++;
            }
        }
        return oddCount <= 1;
    }
}

class Solution {
    public int derangeCount(int n) {
        if (n == 1) return 0;
        if (n == 0) return 1;

        int prev2 = 1; // D(0) = 1
        int prev1 = 0; // D(1) = 0
        int cur = 0;

        for (int i = 2; i <= n; i++) {
            cur = (i - 1) * (prev1 + prev2);
            prev2 = prev1;
            prev1 = cur;
        }

        return cur;
    }
}

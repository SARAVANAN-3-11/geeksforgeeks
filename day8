class Solution {
    int[] pushZerosToEnd(int[] arr) {
        int n = arr.length;
        int nonZeroIndex = 0;
        
        // Move all non-zero elements to front
        for (int i = 0; i < n; i++) {
            if (arr[i] != 0) {
                arr[nonZeroIndex++] = arr[i];
            }
        }
        
        // Fill remaining positions with zeros
        while (nonZeroIndex < n) {
            arr[nonZeroIndex++] = 0;
        }
        
        return arr;
    }
}
